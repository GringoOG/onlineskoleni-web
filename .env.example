# App URL (HTTPS v produkci – GoPay vyžaduje platné callback URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Objednávky + GoPay (Prisma) – lokálně SQLite:
DATABASE_URL="file:./dev.db"

# LMS tabulky (Drizzle) – PostgreSQL ze Supabase nebo Neon:
# Supabase: Project Settings → Database → Connection string (URI, režim Transaction pooler)
# Neon: Dashboard → Connection string
# LMS_DATABASE_URL="postgresql://user:password@host:5432/postgres?sslmode=require"

# GoPay – sandbox credentials z https://account.gopay.com/
GOPAY_GOID=
GOPAY_CLIENT_ID=
GOPAY_CLIENT_SECRET=
# Sandbox: https://gw.sandbox.gopay.com/api
# Produkce: https://gateway.gopay.com/api
GOPAY_GATEWAY_URL=https://gw.sandbox.gopay.com/api

# Volitelné – e-maily (https://resend.com)
# RESEND_API_KEY=
# RESEND_FROM=OnlineŠkolení <noreply@vase-domena.cz>
# ORDER_NOTIFY_EMAIL=info@onlineskoleni.eu
# Po zaplacení objednávky se studentovi pošle uvítací e-mail s přihlašovacími údaji (stejný RESEND_API_KEY).
