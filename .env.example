# App URL (HTTPS v produkci – GoPay callbacky a odkazy v e-mailech)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL (Supabase) – objednávky (Prisma) + LMS (Drizzle) ve STEJNÉ databázi
# Supabase: Project Settings → Database → Connection string (Transaction pooler, port 6543 nebo 5432)
# Na Vercelu používejte Transaction pooler (port 6543), ne Session (5432):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
#
# Volitelný alias (zpětná kompatibilita); pokud chybí, použije se DATABASE_URL:
# LMS_DATABASE_URL=

# GoPay – sandbox credentials z https://account.gopay.com/
GOPAY_GOID=
GOPAY_CLIENT_ID=
GOPAY_CLIENT_SECRET=
# Sandbox: https://gw.sandbox.gopay.com/api
# Produkce: https://gateway.gopay.com/api
GOPAY_GATEWAY_URL=https://gw.sandbox.gopay.com/api

# Resend – e-maily (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=OnlineŠkolení <noreply@vase-overena-domena.cz>
# ORDER_NOTIFY_EMAIL=info@onlineskoleni.eu

# Google Ads – globální tag (gtag.js), veřejné ID
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-17515137667
# NEXT_PUBLIC_GA4_ID=G-MYJ1MTYE91
# NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION=AW-17515137667/wjdgCLH7scscEIOV759B

# Vercel Cron – připomínky certifikátů + fronta generátoru ilustrací (každou minutu)
# CRON_SECRET=long-random-string

# Replicate – hromadný generátor ilustrací (Flux.1-dev)
# REPLICATE_API_TOKEN=r8_xxxxxxxx
# Volitelně rychlejší model: REPLICATE_FLUX_MODEL=black-forest-labs/flux-schnell

# Administrace TechnikPO – role a přihlášení
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=strong-secret-password
# ADMIN_ORDERS_USERNAME=objednavky
# ADMIN_ORDERS_PASSWORD=...
# ADMIN_IMAGE_USERNAME=obrazky
# ADMIN_IMAGE_PASSWORD=...
# ADMIN_SESSION_SECRET=optional-separate-secret (doporučeno na Vercelu)
# Přihlášení funguje z env proměnných i bez seed skriptu. Seed volitelně synchronizuje účty do DB:
# npm run seed:admin-users
