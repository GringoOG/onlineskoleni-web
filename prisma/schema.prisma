generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id                String   @id @default(cuid())
  orderNumber       String   @unique
  status            String   @default("PENDING")
  companyName       String
  ico               String?
  contactName       String
  email             String
  phone             String?
  totalAmountHalere Int
  currency          String      @default("CZK")
  paymentMethod     String?     // INVOICE, CASH, GOPAY, BANK_TRANSFER
  adminNote         String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  enrollmentProcessedAt  DateTime?
  items                  OrderItem[]
  payment                Payment?
}

model OrderItem {
  id                String @id @default(cuid())
  orderId           String
  order             Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courseSlug        String
  name              String
  quantity          Int
  unitPriceHalere   Int
  lineTotalHalere   Int
}

model Payment {
  id             String   @id @default(cuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gopayPaymentId String?  @unique
  state          String   @default("CREATED")
  gwUrl          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model GeneratedImage {
  id                  String    @id @default(uuid())
  fileName            String
  prompt              String
  imageUrl            String?
  status              String    @default("PENDING")
  errorMessage        String?
  processingStartedAt DateTime?
  replicatePredictionId String?
  createdAt           DateTime  @default(now())
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
