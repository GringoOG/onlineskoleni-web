{
  "framework": "nextjs",
  "buildCommand": "prisma generate && npm run build",
  "functions": {
    "src/app/api/admin/generator/process/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/admin/generator/download/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/certificate-expiry",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/generator-queue",
      "schedule": "* * * * *"
    }
  ]
}
